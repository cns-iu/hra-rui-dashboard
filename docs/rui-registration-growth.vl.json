{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "url": "rui-registration-growth.csv"
  },
  "width": "container",
  "height": "container",
  "padding": {
    "right": 35,
    "left": 5,
    "bottom": 50
  },
  "config": {
    "font": "Metropolis",
    "axis": {
      "labelFontSize": 14,
      "titleFontSize": 14,
      "titleFontWeight": 500,
      "labelFontWeight": 500,
      "titleLineHeight": 21,
      "labelLineHeight": 21,
      "titleColor": "#201E3D",
      "labelColor": "#4B4B5E",
      "titlePadding": 20
    },
    "legend": {
      "labelFontSize": 14,
      "titleFontSize": 14,
      "titleLineHeight": 21,
      "titleColor": "#201E3D",
      "labelColor": "#4B4B5E",
      "titleFontWeight": 500,
      "labelFontWeight": 500
    }
  },
  "mark": {
    "type": "area",
    "point": false,
    "tooltip": true,
    "strokeWidth": 4
  },
  "transform": [
    {
      "filter": {
        "param": "selected_data_source"
      }
    }
  ],
  "params": [
    {
      "name": "user-selection",
      "select": {
        "type": "point",
        "fields": [
          "group"
        ]
      },
      "bind": "legend"
    },
    {
      "name": "selected_data_source",
      "value": "HuBMAP Datasets",
      "select": {
        "type": "point",
        "fields": [
          "data_source"
        ]
      },
      "bind": {
        "input": "select",
        "options": [
          "HuBMAP Datasets",
          "HuBMAP Blocks",
          "SenNet Datasets",
          "SenNet Blocks",
          "CTann",
          "KPMP Healthy",
          "KPMP Unhealthy",
          "CIFAR",
          "OMAP"
        ],
        "name": "Data Source "
      }
    }
  ],
  "encoding": {
    "x": {
      "field": "date",
      "title": "Date",
      "axis": {
        "labelAngle": -45
      }
    },
    "y": {
      "field": "count",
      "type": "quantitative",
      "title": "Count",
      "axis": {
        "labelAngle": -45,
        "labelOverlap": false
      }
    },
    "color": {
      "field": "group",
      "type": "nominal",
      "title": "Status",
      "scale": {
        "domain": [
          "Unregistered",
          "Exempt",
          "Registered"
        ],
        "range": [
          "#EA4335",
          "#FBC31D",
          "#34A853"
        ]
      }
    },
    "opacity": {
      "condition": {
        "param": "user-selection",
        "value": 1
      },
      "value": 0.2
    }
  }
}
